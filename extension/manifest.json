{
  "manifest_version": 3,
  "name": "Axiom Extractor",
  "version": "1.0",
  "description": "Extracts values from TradingView blob iframe",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/"
  ],
  "background": {
	  "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://axiom.trade/meme/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
  {
    "resources": ["injected.js"],
    "matches": ["<all_urls>"]
  }
]

}
